# Ollama local API endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Runtime model used by the chatbot backend.
# Small-model suggestions for low-resource machines:
# - qwen2.5:3b-instruct
# - phi3:mini
# - gemma2:2b
OLLAMA_MODEL=qwen2.5:3b-instruct

# Backend port and upstream timeout budget in milliseconds.
PORT=3001
REQUEST_TIMEOUT_MS=20000

#RUN_LLM_TESTS=1